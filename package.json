{
  "name": "@the2alert/blog-test",
  "version": "1.0.0",
  "description": "Blog Test Back-End.",
  "main": "./dist/index.js",
  "license": "ISC",
  "private": true,
  "scripts": {
    "start": "cross-env NODE_ENV=production node --no-deprecation ./build/index.js",
    "build": "tsc && yarn swc ./src -d ./build",
    "dev": "cross-env NODE_ENV=development dotenv -e .env -- nodemon --watch \"./src/**/*\" --signal SIGTERM --exec node --no-deprecation -r @swc-node/register ./src/index.ts",
    "dev:start": "cross-env NODE_ENV=development node --no-deprecation ./build/index.js",
    "lint": "eslint ./src --ext .ts",
    "lint:fix": "yarn lint --fix",
    "test": "tsc && yarn lint",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\" \"config/**/*.yml\"",
    "migrate": "dotenv -e .env -- yarn prisma db push",
    "studio": "dotenv -e .env -- yarn prisma studio"
  },
  "author": "The2Alert",
  "devDependencies": {
    "@swc-node/register": "^1.6.8",
    "@swc/cli": "^0.1.63",
    "@swc/core": "^1.3.99",
    "@swc/helpers": "^0.5.3",
    "@swc/types": "^0.1.17",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "^3.5.1",
    "prisma": "^6.3.1",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "bcrypt": "^5.1.1",
    "chalk": "^4.1.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^8.0.0",
    "express": "^4.18.2",
    "http-status": "^1.6.2",
    "ioredis": "^5.6.0",
    "jsonwebtoken": "^9.0.2",
    "markdown-it-async": "1.4.2",
    "mime-types": "^3.0.1",
    "multer": "^1.4.5-lts.2",
    "nodemon": "^3.0.1",
    "pg": "^8.13.3",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.33.5",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.8.2",
    "winston-daily-rotate-file": "^4.7.1",
    "yaml": "^2.3.2",
    "zod": "^4.1.8",
    "zod-openapi": "^5.4.6"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
